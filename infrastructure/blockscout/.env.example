# TPIX Chain Explorer — Blockscout Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วตั้งค่าตามเซิร์ฟเวอร์จริง

# Database
DB_PASSWORD=tpix_explorer_secret

# TPIX Chain RPC (ชี้ไปที่ validator node)
RPC_URL=http://localhost:8545
WS_URL=ws://localhost:8545

# Security — เปลี่ยนเป็น random string ก่อน deploy production
SECRET_KEY_BASE=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING_FOR_PRODUCTION_USE
